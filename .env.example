# 复制为 .env 后填写（勿将 .env 提交到 Git）
# 流水线已从仓库根目录自动 load_dotenv；也可在 shell 中手动 export

# ---------- LLM（pipeline/model_client.py）----------
# deepseek | qwen | openai
LLM_PROVIDER=deepseek

# 按所选提供商填写对应 Key，未用的可留空
DEEPSEEK_API_KEY=
QWEN_API_KEY=
OPENAI_API_KEY=

# 可选：默认模型（不设则 deepseek→deepseek-chat，qwen→qwen-turbo，openai→gpt-4o-mini）
# LLM_MODEL=deepseek-chat

# 可选：自定义网关（一般不必改）
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# 可选：美元计价覆盖（JSON 字符串，单位：美元 / 百万 tokens）
# LLM_PRICING_JSON={"deepseek-chat":{"input":0.2,"output":0.8}}

# ---------- 流水线采集（pipeline/pipeline.py）----------
# GitHub Search API（可选，提高限流与私有资源访问）
# GITHUB_TOKEN=
# GITHUB_SEARCH_QUERY=AI OR LLM OR agent OR RAG

# 覆盖 rss_sources.yaml：逗号分隔多个 RSS URL（可选）
# RSS_URLS=
