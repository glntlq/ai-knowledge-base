{
  "name": "organizer_agent",
  "description": "整理 Agent：知识库维护，包括去重、分类、归档、质量检查",
  "type": "periodic",
  "schedule": "0 3 * * *",
  "tools": [
    "deduplicate_by_hash",
    "categorize_by_topic",
    "validate_schema",
    "archive_old_entries"
  ],
  "skills": [
    "data_deduplication",
    "topic_modeling",
    "quality_assurance"
  ],
  "config": {
    "deduplication_method": "content_hash",
    "similarity_threshold": 0.9,
    "topic_categories": ["llm", "agent", "framework", "tool", "research", "tutorial"],
    "archive_age_days": 30,
    "archive_dir": "knowledge/archived/",
    "quality_checks": ["required_fields", "url_valid", "summary_not_empty"]
  },
  "workflow": [
    "scan_articles_directory",
    "deduplicate_entries",
    "categorize_by_topic",
    "validate_schema_compliance",
    "archive_old_entries",
    "update_index",
    "generate_report"
  ],
  "output_spec": {
    "deduplication_report": "knowledge/processed/reports/deduplication_{date}.json",
    "topic_distribution": "knowledge/processed/reports/topics_{date}.json",
    "quality_report": "knowledge/processed/reports/quality_{date}.json",
    "updated_index": "knowledge/articles_index.json"
  },
  "error_handling": {
    "on_duplicate": "keep_newest",
    "on_invalid_schema": "move_to_quarantine",
    "quarantine_dir": "knowledge/quarantine/"
  },
  "logging": {
    "level": "INFO",
    "format": "json"
  }
}