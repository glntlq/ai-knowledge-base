{
  "name": "analyzer_agent",
  "description": "分析 Agent：对原始内容进行 AI 分析，提取摘要、打标签、结构化存储",
  "type": "triggered",
  "trigger": {
    "type": "file_watcher",
    "watch_path": "knowledge/raw/",
    "pattern": "**/*.html"
  },
  "tools": [
    "summarize_with_llm",
    "extract_tags",
    "detect_language",
    "extract_metadata"
  ],
  "skills": [
    "nlp_processing",
    "content_analysis",
    "json_schema_validation"
  ],
  "config": {
    "llm_provider": "deepseek",
    "llm_model": "deepseek-reasoner",
    "summary_length_words": 200,
    "max_tags": 5,
    "output_schema": "knowledge_schema_v1",
    "output_dir": "knowledge/articles/"
  },
  "processing_pipeline": [
    "load_raw_content",
    "extract_text",
    "generate_summary",
    "extract_tags",
    "detect_language",
    "validate_metadata",
    "save_structured_json"
  ],
  "output_spec": {
    "article_json": "knowledge/articles/{id}.json",
    "analysis_log": "knowledge/processed/logs/{timestamp}_analysis.log"
  },
  "error_handling": {
    "retry_attempts": 2,
    "on_failure": "move_to_quarantine",
    "quarantine_dir": "knowledge/quarantine/"
  },
  "logging": {
    "level": "INFO",
    "format": "json"
  }
}