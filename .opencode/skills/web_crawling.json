{
  "name": "web_crawling",
  "description": "网页爬取技能：支持 GitHub Trending 和 Hacker News 的数据采集",
  "implementation": {
    "module": "src.crawlers.github_trending",
    "class": "GitHubTrendingCrawler",
    "functions": ["fetch_trending_repos", "extract_repo_info"]
  },
  "dependencies": ["requests", "beautifulsoup4", "lxml"],
  "config": {
    "user_agent": "AI-Knowledge-Base-Crawler/1.0",
    "timeout_seconds": 30,
    "rate_limit_per_minute": 12
  },
  "error_handling": {
    "retry_status_codes": [429, 500, 502, 503, 504],
    "max_retries": 3
  }
}